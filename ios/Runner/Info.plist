<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Bottles Up User</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>bottles_up_user</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>

	<!-- ✅ Deep links and Google Sign-In URL Schemes -->
	<key>CFBundleURLTypes</key>
	<array>
		<!-- Custom deep link -->
		<dict>
			<key>CFBundleURLName</key>
			<string>bottlesup.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>bottlesup</string>
			</array>
		</dict>

		<!-- HTTP/HTTPS links -->
		<dict>
			<key>CFBundleURLName</key>
			<string>bottlesup.web.http</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>http</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>bottlesup.web.https</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>https</string>
			</array>
		</dict>

		<!-- ✅ Google Sign-In URL Scheme (must exactly match Cloud Console) -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.386838494006-tqo6ags4qbr2onoertn9e716jvv4rdnk</string>
			</array>
		</dict>
	</array>

	<!-- ✅ Google Sign-In client IDs -->
	<key>GIDClientID</key>
	<string>386838494006-tqo6ags4qbr2onoertn9e716jvv4rdnk.apps.googleusercontent.com</string>
	<key>GIDServerClientID</key>
	<string>386838494006-j472kn5eh58552cln304f0b9l4daf7gh.apps.googleusercontent.com</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>This app needs access to your camera to take photos for your profile and event posts.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>This app needs access to your location to show nearby clubs and events.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>This app needs access to your location to show nearby clubs and events.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>This app needs access to your photo library to select photos for your profile and event posts.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
